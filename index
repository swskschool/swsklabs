<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบลงเวลาเข้าห้องปฏิบัติการ (Lab Check-in)</title>
    <!-- โหลด Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .container { max-width: 800px; margin-top: 30px; }
        .card { box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    </style>
</head>
<body>

<div class="container">
    <h2 class="text-center mb-4">ระบบลงเวลาเข้าห้องปฏิบัติการ</h2>

    <!-- ระบุ Web App URL -->
    <div class="alert alert-warning">
        <label for="scriptUrl" class="form-label fw-bold">Google Apps Script Web App URL (วาง URL ที่นี่ก่อนใช้งาน)</label>
        <input type="text" class="form-control" id="scriptUrl" placeholder="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec">
    </div>

    <!-- แท็บเมนู -->
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="checkin-tab" data-bs-toggle="tab" data-bs-target="#checkin" type="button" role="tab">ลงเวลาเข้าใช้งาน</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="admin-tab" data-bs-toggle="tab" data-bs-target="#admin" type="button" role="tab">นำเข้าข้อมูล (Admin)</button>
        </li>
    </ul>

    <!-- เนื้อหาแต่ละแท็บ -->
    <div class="tab-content" id="myTabContent">
        
        <!-- แท็บ: ลงเวลา (Check-in) -->
        <div class="tab-pane fade show active p-4 bg-white border border-top-0" id="checkin" role="tabpanel">
            <form id="checkinForm">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">เลขประจำตัวนักเรียน</label>
                        <input type="text" class="form-control" name="studentId" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ชื่อ-นามสกุล</label>
                        <input type="text" class="form-control" name="name" required>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">ชั้น</label>
                        <input type="text" class="form-control" name="class" placeholder="เช่น ม.4/1" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ห้องปฏิบัติการ</label>
                        <input type="text" class="form-control" name="lab" placeholder="เช่น Lab คอมพิวเตอร์ 1" required>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">วันที่</label>
                        <input type="date" class="form-control" id="dateInput" name="date" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">เวลา</label>
                        <input type="time" class="form-control" id="timeInput" name="time" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100" id="btnCheckin">บันทึกข้อมูล</button>
            </form>
        </div>

        <!-- แท็บ: นำเข้าข้อมูล (Admin) -->
        <div class="tab-pane fade p-4 bg-white border border-top-0" id="admin" role="tabpanel">
            
            <!-- นำเข้านักเรียน -->
            <div class="mb-4">
                <h5>1. นำเข้าข้อมูลนักเรียน (JSON)</h5>
                <p class="text-muted small mb-1">รูปแบบ: [{"id":"12345", "name":"สมชาย ใจดี", "class_":"ม.4/1"}]</p>
                <textarea class="form-control mb-2" id="jsonStudents" rows="3"></textarea>
                <button class="btn btn-success btn-sm" onclick="importData('importStudents', 'jsonStudents')">อัปเดตข้อมูลนักเรียน</button>
            </div>

            <hr>

            <!-- นำเข้าห้องแล็บ -->
            <div>
                <h5>2. นำเข้าข้อมูลห้องปฏิบัติการ (JSON)</h5>
                <p class="text-muted small mb-1">รูปแบบ: ["Lab วิทยาศาสตร์", "Lab คอมพิวเตอร์"]</p>
                <textarea class="form-control mb-2" id="jsonLabs" rows="3"></textarea>
                <button class="btn btn-info btn-sm text-white" onclick="importData('importLabs', 'jsonLabs')">อัปเดตข้อมูลห้องแล็บ</button>
            </div>

        </div>
    </div>
</div>

<!-- โหลด Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // ตั้งค่า วันที่ และ เวลา ปัจจุบันให้ฟอร์มอัตโนมัติ
    document.getElementById('dateInput').valueAsDate = new Date();
    const now = new Date();
    document.getElementById('timeInput').value = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');

    // ฟังก์ชันส่งข้อมูล Check-in
    document.getElementById('checkinForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const url = document.getElementById('scriptUrl').value.trim();
        if (!url) {
            alert('กรุณาระบุ Web App URL ก่อน');
            return;
        }

        const btn = document.getElementById('btnCheckin');
        btn.disabled = true;
        btn.innerText = 'กำลังบันทึก...';

        const formData = new FormData(this);
        const data = new URLSearchParams();
        data.append('action', 'checkin');
        for (const pair of formData) {
            data.append(pair[0], pair[1]);
        }

        fetch(url, { method: 'POST', body: data })
            .then(response => response.json())
            .then(result => {
                if(result.status === 'success') {
                    alert('บันทึกข้อมูลสำเร็จ!');
                    this.reset();
                    // เซ็ตเวลาใหม่
                    document.getElementById('dateInput').valueAsDate = new Date();
                    document.getElementById('timeInput').value = new Date().getHours().toString().padStart(2, '0') + ':' + new Date().getMinutes().toString().padStart(2, '0');
                } else {
                    alert('เกิดข้อผิดพลาด: ' + result.message);
                }
            })
            .catch(error => alert('ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ (ตรวจสอบ URL หรือการตั้งค่าสิทธิ์)'))
            .finally(() => {
                btn.disabled = false;
                btn.innerText = 'บันทึกข้อมูล';
            });
    });

    // ฟังก์ชันส่งข้อมูล Import (นักเรียน และ แล็บ)
    function importData(actionType, textareaId) {
        const url = document.getElementById('scriptUrl').value.trim();
        if (!url) {
            alert('กรุณาระบุ Web App URL ก่อน');
            return;
        }

        const rawData = document.getElementById(textareaId).value.trim();
        if (!rawData) {
            alert('กรุณากรอกข้อมูล JSON ก่อน');
            return;
        }

        // ตรวจสอบความถูกต้องของ JSON เบื้องต้น
        try {
            JSON.parse(rawData);
        } catch (e) {
            alert('รูปแบบ JSON ไม่ถูกต้อง กรุณาตรวจสอบอีกครั้ง');
            return;
        }

        const data = new URLSearchParams();
        data.append('action', actionType);
        data.append('data', rawData);

        fetch(url, { method: 'POST', body: data })
            .then(response => response.json())
            .then(result => {
                if(result.status === 'success') {
                    alert('อัปเดตข้อมูลสำเร็จ!');
                    document.getElementById(textareaId).value = '';
                } else {
                    alert('เกิดข้อผิดพลาด: ' + result.message);
                }
            })
            .catch(error => alert('ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้'));
    }
</script>
</body>
</html>
